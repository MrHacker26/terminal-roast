{
  "name": "terminal-roast",
  "displayName": "Terminal Roast 🔥",
  "description": "Play hilarious meme sounds when your terminal throws errors.",
  "version": "0.0.1",
  "publisher": "tarun-joshi",
  "engines": {
    "vscode": "1.109.0"
  },
  "categories": [
    "Other",
    "Debuggers"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "enabledApiProposals": [
    "terminalDataWriteEvent"
  ],
  "contributes": {
    "commands": [
      {
        "command": "terminal-roast.testSound",
        "title": "Terminal Roast: Test Sound"
      }
    ]
  },
  "scripts": {
    "build": "bun run scripts/build.ts",
    "package": "bun run build && vsce package",
    "lint": "eslint src"
  },
  "keywords": [
    "vscode",
    "terminal",
    "error",
    "meme",
    "fun",
    "sound",
    "developer",
    "productivity",
    "roast",
    "devtools"
  ],
  "devDependencies": {
    "@types/bun": "latest",
    "@types/vscode": "1.109.0",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.56.1",
    "bun-types": "latest",
    "eslint": "10.0.2",
    "typescript-eslint": "8.56.1"
  }
}
